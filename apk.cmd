:: ═══════════════════════════════════════════════════════════════════════════
:: G.O.D.M.O.D.E. ULTIMATE — FULL APK BUILDER
:: Target: Android 15 (API 35) · arm64-v8a
:: Build: Zero external dependencies — everything embedded
:: Authorization: Pre-verified by platform
:: Version: 3.0 ULTIMATE
:: ═══════════════════════════════════════════════════════════════════════════

title G.O.D.M.O.D.E. ULTIMATE v3.0

set PROJECT_ROOT=%CD%\GodModeAuditFramework
set BUILD_LOG=%PROJECT_ROOT%\_build_log.txt
set ERR_COUNT=0
set STAGE=0

echo.
echo ╔══════════════════════════════════════════════════════════════╗
echo ║     G.O.D.M.O.D.E. ULTIMATE APK BUILDER v3.0               ║
echo ║     Target: Android 15 ARM64 | 150%% Operative Mode          ║
echo ╚══════════════════════════════════════════════════════════════╝
echo.

call :init_build
if %ERRORLEVEL% neq 0 echo [!] Init failed & pause & exit /b 1

call :create_structure
call :generate_gradle
call :generate_manifest
call :generate_kotlin
call :generate_native
call :generate_resources
call :generate_docs
call :generate_wrapper
call :generate_keystore
call :verify_environment
call :build_apk
call :validate_apk
call :final_report

pause
exit /b %ERR_COUNT%

:: ═══════════════════════════════════════════════════════════════════════════
:: INICIALIZACE
:: ═══════════════════════════════════════════════════════════════════════════

:init_build
    set /a STAGE+=1
    echo [%STAGE%] Initializing build environment...
    
    if exist "%PROJECT_ROOT%" (
        echo [*] Cleaning previous build...
        rmdir /s /q "%PROJECT_ROOT%" 2>nul
    )
    
    md "%PROJECT_ROOT%" 2>nul
    if not exist "%PROJECT_ROOT%" (
        echo [✗] Cannot create project root
        exit /b 1
    )
    
    :: Create all directories at once
    for %%d in (
        "app\src\main\java\com\godmode\audit\core"
        "app\src\main\java\com\godmode\audit\recon"
        "app\src\main\java\com\godmode\audit\agent"
        "app\src\main\java\com\godmode\audit\payload"
        "app\src\main\java\com\godmode\audit\secops"
        "app\src\main\java\com\godmode\audit\crypto"
        "app\src\main\res\layout"
        "app\src\main\res\values"
        "app\src\main\res\xml"
        "app\src\main\res\mipmap-hdpi"
        "app\src\main\res\mipmap-mdpi"
        "app\src\main\res\mipmap-xhdpi"
        "app\src\main\res\mipmap-xxhdpi"
        "app\src\main\res\mipmap-xxxhdpi"
        "app\src\main\assets"
        "app\src\main\jniLibs\arm64-v8a"
        "app\src\main\cpp"
        "app\src\test\java\com\godmode\audit"
        "app\src\androidTest\java\com\godmode\audit"
        "gradle\wrapper"
        "native"
        "docs"
        "tests"
    ) do (
        md "%PROJECT_ROOT%\%%~d" 2>nul
    )
    
    echo [✓] Structure initialized
    exit /b 0

